CF_DNS_API_TOKEN=
ACME_EMAIL=

# PostgreSQL superuser (used by init only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Moods production database
MOODS_DB_PASSWORD=

# Moods development database
MOODS_DEV_DB_PASSWORD=

# pgAdmin
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=
