{
  "name": "moods",
  "main": "expo-router/entry",
  "version": "2.1.1",
  "scripts": {
    "gql:generate": "python3 ../graphql/generate.py",
    "prestart": "npm run gql:generate",
    "start": "EXPO_PUBLIC_APP_VARIANT=local expo start",
    "start:dev": "EXPO_PUBLIC_APP_VARIANT=dev expo start",
    "android": "npm run gql:generate && EXPO_PUBLIC_APP_VARIANT=local expo run:android",
    "android:dev": "npm run gql:generate && EXPO_PUBLIC_APP_VARIANT=dev expo run:android",
    "build:dev": "npm run gql:generate && eas build --profile preview --platform android",
    "build:release": "npm run gql:generate && eas build --profile production --platform android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.1.8",
    "@urql/devtools": "^2.0.3",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "graphql": "^16.12.0",
    "lodash.debounce": "^4.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "urql": "^5.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/lodash.debounce": "^4.0.9",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
